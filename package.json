{
  "name": "credential-lens",
  "version": "1.0.0",
  "description": "Credential Lens monorepo for OCR-driven, evidence-grounded credential extraction.",
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "dev": "concurrently -n api,web -c cyan,yellow \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build --workspaces --if-present",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:generate": "npm run prisma:generate -w apps/api",
    "compose:up": "docker compose up -d postgres",
    "compose:down": "docker compose down"
  },
  "keywords": [
    "ocr",
    "document-extraction",
    "sqlite",
    "nextjs",
    "express"
  ],
  "license": "ISC",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/types",
    "packages/crypto",
    "apps/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "pdf-lib": "^1.17.1"
  },
  "overrides": {
    "tar": "7.5.15",
    "postcss": "8.5.15"
  },
  "dependencies": {
    "strip-comments": "^2.0.1"
  }
}
