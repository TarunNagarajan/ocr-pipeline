NODE_ENV=development
PORT=4000
DATABASE_URL=file:./dev.db
WEB_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
JWT_SECRET=replace-with-at-least-32-random-bytes
DOCUMENT_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes
CREDENTIAL_ENCRYPTION_KEY=optional-legacy-fallback-key
STORAGE_ROOT=./storage
STORAGE_BACKEND=local
GCS_BUCKET=
MAX_UPLOAD_MB=10
LLM_MODE=none
VLM_MODE=none
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_MODEL=gpt-4.1-mini
OPENAI_COMPAT_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
VERTEX_LLM_MODEL=gemini-2.5-flash
VERTEX_VLM_MODEL=gemini-2.5-flash
